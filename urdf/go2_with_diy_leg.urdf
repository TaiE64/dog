      <inertia ixx="0.000059647" ixy="0.0" ixz="0.0" iyy="0.000111842" iyz="0.0" izz="0.000059647" />
    </inertial>
  </link>
  <joint name="FL_thigh_rotor_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 -0.00015 0" />
    <parent link="FL_hip" />
    <child link="FL_thigh_rotor" />
  </joint>
  <!-- ============================================================ -->
