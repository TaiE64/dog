Panels:
  - Class: rviz/Displays
    Name: Displays
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz/Grid
      Name: Grid
      Value: true
    - Class: rviz/RobotModel
      Name: RobotModel
      Value: true
  Global Options:
    Fixed Frame: base
  Tools:
    - Class: rviz/MoveCamera
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 2.0
      Focal Point:
        X: 0
        Y: 0
        Z: 0
