<launch>
    <!-- Gazebo + Walk controller (unchanged) -->
    <include file="$(find leg_manipulator)/launch/gazebo_walk.launch"/>

    <!-- Bridge: converts MoveIt trajectories to JointPositionController commands -->
    <node name="arm_trajectory_bridge" pkg="leg_manipulator" type="arm_trajectory_bridge.py" output="screen"/>

    <!-- MoveIt move_group -->
    <include file="$(find leg_manipulator_moveit_config)/launch/move_group.launch">
        <arg name="allow_trajectory_execution" value="true"/>
    </include>

    <!-- MoveIt RViz -->
    <include file="$(find leg_manipulator_moveit_config)/launch/moveit_rviz.launch"/>
</launch>
