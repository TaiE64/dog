<launch>
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="paused" value="true"/>
        <arg name="world_name" value="$(find leg_manipulator)/launch/empty_world_custom.world"/>
    </include>

    <param name="robot_description" textfile="$(find leg_manipulator)/urdf/go2_with_diy_leg.urdf"/>

    <node name="spawn_model" pkg="gazebo_ros" type="spawn_model"
        args="-param robot_description -urdf -model go2_with_diy_leg -z 0.4"
        output="screen"/>

    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>

    <!-- Load controller config -->
    <rosparam file="$(find leg_manipulator)/config/joint_controllers.yaml" command="load"/>

    <!-- Spawn controllers (Go2 joints only) -->
    <node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false"
        output="screen" args="
            joint_state_controller
            go2_effort_controller
            FL_diy_joint1_controller FL_diy_joint2_controller FL_diy_joint3_controller FL_diy_joint4_controller
            diy_joint1_controller diy_joint2_controller diy_joint3_controller diy_joint4_controller
        "/>

    <!-- Walk controller (RL policy) -->
    <node name="walk_controller" pkg="leg_manipulator" type="walk_controller.py" output="screen">
        <param name="model_path" value="$(env HOME)/dog_ws/walk_model/model_1700.pt"/>
        <param name="deploy_config" value="$(env HOME)/dog_ws/walk_model/params/deploy.yaml"/>
    </node>
</launch>
